{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "node16",

    "lib": ["ES2022"],
    "types": ["node", "vscode"],

    "rootDir": "src",
    "outDir": "out",

    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}