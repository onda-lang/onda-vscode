{
  "name": "onda-vscode",
  "displayName": "Onda",
  "description": "VSCode support for the Onda audio DSL",
  "version": "0.1.7",
  "publisher": "onda-lang",
  "icon": "assets/onda-logo-dark-rect.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitreo12/onda.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:onda",
    "onCommand:onda.restartLanguageServer",
    "onCommand:onda.runFile",
    "onCommand:onda.stopFile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "onda",
        "aliases": [
          "Onda",
          "onda"
        ],
        "extensions": [
          ".onda",
          ".on"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "onda",
        "scopeName": "source.onda",
        "path": "./syntaxes/onda.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "port",
        "superType": "variable",
        "description": "Onda audio input, output, or buffer symbol"
      },
      {
        "id": "state",
        "superType": "variable",
        "description": "Onda init-declared state symbol"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "onda",
        "scopes": {
          "enumMember": [
            "variable.other.constant"
          ],
          "variable": [
            "variable.other.readwrite"
          ],
          "port": [
            "support.variable"
          ],
          "state": [
            "variable.parameter"
          ],
          "parameter": [
            "variable.parameter"
          ],
          "function": [
            "entity.name.function"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "onda.runFile",
        "title": "Onda: Run File"
      },
      {
        "command": "onda.stopFile",
        "title": "Onda: Stop File"
      },
      {
        "command": "onda.restartLanguageServer",
        "title": "Onda: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "Onda",
      "properties": {
        "onda.server.path": {
          "type": "string",
          "description": "Path to the Onda executable. Leave unset to use 'onda' from PATH."
        },
        "onda.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the built-in 'lsp' subcommand."
        },
        "onda.run.theme": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "light"
          ],
          "default": "auto",
          "description": "Theme used by the Onda run panel."
        },
        "onda.run.host": {
          "type": "string",
          "enum": [
            "webview",
            "egui"
          ],
          "default": "webview",
          "description": "Host used by Onda: Run File. 'webview' opens the embedded VS Code panel; 'egui' opens the native egui run window."
        }
      }
    }
  },
  "scripts": {
    "copy-run-ui": "node -e \"require('fs').cpSync('./ui/run/run.html','./out/run.html')\"",
    "compile": "tsc -p ./ && npm run copy-run-ui",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
